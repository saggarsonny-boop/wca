{
  "openapi": "3.0.0",
  "info": {
    "title": "White Collar Academy AI Query API",
    "description": "Secure retrieval endpoint for federal sentencing guidelines, custody point tables, and public mitigation guides.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://whitecollaracademy.com"
    }
  ],
  "paths": {
    "/api/ai/query": {
      "get": {
        "summary": "Query the RAG database",
        "description": "Returns structured JSON summaries of federal guidelines matching search keywords.",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "description": "Keywords or search phrases",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A list of relevant mitigation topics and answers",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "question": {
                        "type": "string"
                      },
                      "answer": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}